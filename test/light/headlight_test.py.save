# headlight_test.py
# Official Quanser pal.products.qcar package — QCar 2 physical hardware
# LEDs array has 8 elements for QCar 2:
#   LEDs[0] = left turn signal
#   LEDs[1] = right turn signal
#   LEDs[2] = left reverse indicator
#   LEDs[3] = right reverse indicator
#   LEDs[4] = brake lights (all 4)
#   LEDs[5] = reverse lights (2)
#   LEDs[6] = LEFT headlamps  (channels 19, 20, 21)
#   LEDs[7] = RIGHT headlamps (channels 22, 23, 24)

import sys
sys.path.insert(0, '/home/nvidia/Documents/Quanser/libraries/python')

import time
import numpy as np
from pal.products.qcar import QCar

def main():
    # Initialize QCar — readMode=0 (immediate I/O), no movement
    car = QCar(readMode=0, frequency=500)

    # 8-element LED array, all OFF to start
    LEDs = np.zeros(8, dtype=np.int8)

    try:
        print("=== QCar 2 Headlight Test ===")

        # ── Turn headlights ON ──
	LEDs[0] =  LEDs[0] =
        LEDs[6] = 1   # Left headlamps ON
        LEDs[7] = 1   # Right headlamps ON

        car.write(throttle=0, steering=0, LEDs=LEDs)
        print("Headlights ON — look at the front of the car!")

        time.sleep(5)   # Keep ON for 5 seconds

        # ── Turn headlights OFF ──
        LEDs[6] = 0
        LEDs[7] = 0

        car.write(throttle=0, steering=0, LEDs=LEDs)
        print("Headlights OFF.")

    finally:
        car.terminate()
        print("Done. QCar terminated safely.")

if __name__ == '__main__':
    main()
